# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/talent_registry"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NATS JetStream
NATS_URL="nats://localhost:4222"

# Redis
REDIS_URL="redis://localhost:6379"

# ZenYa AI Service
ZENYA_API_URL="http://localhost:5055"
ZENYA_API_KEY=""

# Flutto (Rails)
FLUTTO_API_URL="http://localhost:3001"
FLUTTO_API_TOKEN=""

# SMTP (Email)
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@talentregistry.zencube.ai"

# Retention
RETENTION_DAYS="30"
RETENTION_GRACE_DAYS="7"
RETENTION_ANONYMIZATION_SALT="your-salt-here"

# Logging
LOG_LEVEL="info"
NODE_ENV="development"
